{
  "openapi": "3.1.0",
  "info": {
    "title": "Short links Service",
    "version": "0.0.0"
  },
  "tags": [
    {
      "name": "Links"
    }
  ],
  "paths": {
    "/api/links": {
      "post": {
        "operationId": "Widgets_create",
        "summary": "Создание короткой ссылки",
        "parameters": [],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string"
                    },
                    "short_url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "code",
                    "short_url"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "Links"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ]
              }
            }
          }
        }
      }
    },
    "/api/links/{code}/stats": {
      "get": {
        "operationId": "Widgets_stats",
        "summary": "Статистика по ссылке",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    },
                    "code": {
                      "type": "string"
                    },
                    "clicks": {
                      "type": "number"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "url",
                    "code",
                    "clicks",
                    "created_at"
                  ]
                }
              }
            }
          }
        },
        "tags": [
          "Links"
        ]
      }
    }
  },
  "components": {}
}
